#!/usr/bin/env bash
# bin/qa — Code quality script for Bashsmith projects.
# Runs shellcheck on all shell files and bats on all test files.

set -euo pipefail
IFS=$'\n\t'

SHELLCHECK_EXCLUDE="SC1090,SC1091,SC2034,SC2317"
BATS_DIR="bats"

# ── Helpers ───────────────────────────────────────────────────────────────────
print_step() {
  printf "\n\033[1;34m===> %s\033[0m\n" "$1"
}

print_success() {
  printf "\033[1;32m✓ %s\033[0m\n" "$1"
}

print_error() {
  printf "\033[1;31m✗ %s\033[0m\n" "$1"
}

# ── Shellcheck ────────────────────────────────────────────────────────────────
run_shellcheck() {
  print_step "Running Shellcheck..."

  if ! command -v shellcheck &> /dev/null; then
    print_error "shellcheck is not installed. Skipping."
    return 1
  fi

  # Find all .sh files in standard project directories
  local sh_files=()
  while IFS= read -r file; do
    sh_files+=("$file")
  done < <(find bin lib settings -name "*.sh" -type f 2>/dev/null || true)

  # Also check files in bin/ that don't have an extension but are bash scripts
  while IFS= read -r file; do
    if head -n 1 "$file" | grep -q "bash"; then
      sh_files+=("$file")
    fi
  done < <(find bin -type f ! -name "*.*" 2>/dev/null || true)

  # Ensure we have files to lint
  if [[ ${#sh_files[@]} -eq 0 ]]; then
    echo "No Bash files found to lint."
    return 0
  fi

  # Extract unique files
  local unique_files=()
  while IFS= read -r -d '' file; do
    unique_files+=("$file")
  done < <(printf '%s\0' "${sh_files[@]}" | sort -zu)

  echo "Linting ${#unique_files[@]} file(s)..."

  local failed=0
  for file in "${unique_files[@]}"; do
    if shellcheck --exclude="$SHELLCHECK_EXCLUDE" "$file"; then
      echo "  [OK] $file"
    else
      failed=1
    fi
  done

  if [[ "$failed" -eq 0 ]]; then
    print_success "Shellcheck passed."
    return 0
  else
    print_error "Shellcheck failed on one or more files."
    return 1
  fi
}

# ── BATS ──────────────────────────────────────────────────────────────────────
run_bats() {
  print_step "Running BATS tests..."

  if ! command -v bats &> /dev/null; then
    print_error "bats is not installed. Skipping."
    return 1
  fi

  if [[ ! -d "$BATS_DIR" ]]; then
    echo "No $BATS_DIR/ directory found. Skipping BATS tests."
    return 0
  fi

  local test_files=()
  while IFS= read -r file; do
    test_files+=("$file")
  done < <(find "$BATS_DIR" -name "*.bats" -type f 2>/dev/null || true)

  if [[ ${#test_files[@]} -eq 0 ]]; then
    echo "No .bats files found in $BATS_DIR/."
    return 0
  fi

  echo "Running ${#test_files[@]} BATS test(s)..."

  if bats "${test_files[@]}"; then
    print_success "BATS tests passed."
    return 0
  else
    print_error "BATS tests failed."
    return 1
  fi
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
  local failed=0

  run_shellcheck || failed=1
  run_bats || failed=1

  if [[ "$failed" -eq 1 ]]; then
    print_error "Code quality checks failed."
    exit 1
  else
    print_step "All checks passed!"
    exit 0
  fi
}

main "$@"
